[["1757483-111","black-walnut","2006 Kit Cir, Austin, TX 78758, USA","Black walnut","Juglans nigra",30.405453,-97.686252,"Access: Public.","community","https://fallingfruit.org/locations/1757483","2025-05-19 05:19:52 UTC","Public","open",true,"Falling Fruit access: Public."],["2109317-98","blackberry","12907 Scofield Farms Dr, Austin, TX 78727, USA","Dewberry","Rubus",30.416218,-97.680575,"You can find dewberries along the trail and they are found in the forest as well. Start in March, the bulk of them are in April, and you might still be able to get some into May. Access: Public. Falling Fruit season: March-May.","community","https://fallingfruit.org/locations/2109317","2024-12-27 03:35:32 UTC","Public","open",true,"Falling Fruit access: Public."],["1755917-98","blackberry","14943 Wells Port Dr, Austin, TX 78728, USA","Dewberry","Rubus",30.446058,-97.675002,"Falling Fruit record for Dewberry.","community","https://fallingfruit.org/locations/1755917","2025-05-21 05:11:39 UTC","","unknown",false,"Access unknown in Falling Fruit."],["2109316-20","fig","2113 Equestrian Trail, Austin, TX 78727, USA","Common fig","Ficus carica",30.428498,-97.689886,"There is two large fig bushes along the fence line, but the property line does not start until 7 feet behind the fence, so its not private property for 7 feet after the fence. Access: Private but overhanging. Falling Fruit season: August-October.","community","https://fallingfruit.org/locations/2109316","2024-12-27 03:30:24 UTC","Private but overhanging","private",false,"Falling Fruit access: Private but overhanging."],["2114772-705","grape","12113 Metric Blvd, Austin, TX 78758, USA","Mustang grape","Vitis mustangensis",30.4035138150971,-97.69659769096533,"In apartment complex by the second pool, on the fence on the edge of the park/woods. Access: Private.","community","https://fallingfruit.org/locations/2114772","2025-07-03 13:46:55 UTC","Private","private",false,"Falling Fruit access: Private."],["2114773-705","grape","12113 Metric Blvd, Austin, TX 78758, USA","Mustang grape","Vitis mustangensis",30.403805137966813,-97.69614865928733,"Mustang grape vines gigantic ones. There\u2019s not a gigantic amount of grapes though, pretty average for a good fruit bearing vine. Access: Public.","community","https://fallingfruit.org/locations/2114773","2025-07-03 13:46:40 UTC","Public","open",true,"Falling Fruit access: Public."],["1805343-705","grape","2001 W Parmer Ln, Austin, TX 78727, USA","Mustang grape","Vitis mustangensis",30.413396,-97.694463,"A very large and well-established mustang grape vine growing up a mulberry tree. Produces a lot of grapes pretty consistently every summer, though not for very long. Technically on public land, since the tree's on the outside of the fences, but more accessible","community","https://fallingfruit.org/locations/1805343","2021-09-07 05:23:51 UTC","Public","open",true,"Falling Fruit access: Public."],["678062-93","hickory","12138","Pecan","Carya illinoinensis",30.4023088157046,-97.6852491150395,"[1x] Carya illinoinensis. 12138 Lamar Blvd N. Planted in 2010.","community","https://fallingfruit.org/locations/678062","2016-12-08 11:36:10 UTC","","unknown",false,"Access unknown in Falling Fruit."],["1766927-93","hickory","12221 Tanglewild Dr, Austin, TX 78758, USA","Pecan","Carya illinoinensis",30.4062632,-97.6926781,"Near sidewalk Access: Private but overhanging.","community","https://fallingfruit.org/locations/1766927","2025-05-11 05:06:54 UTC","Private but overhanging","private",false,"Falling Fruit access: Private but overhanging."],["1757458-93","hickory","1390 Tamar Ln, Austin, TX 78727, USA","Pecan","Carya illinoinensis",30.417102,-97.67986,"Access: Public.","community","https://fallingfruit.org/locations/1757458","2025-05-20 05:00:32 UTC","Public","open",true,"Falling Fruit access: Public."],["667787-179","ink-oak","12138","Bur oak","Quercus macrocarpa",30.4021500136736,-97.6850947973573,"[1x] Quercus macrocarpa. 12138 Lamar Blvd N. Planted in 2010.","