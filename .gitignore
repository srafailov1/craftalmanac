# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# macOS
.DS_Store

# Phenology build scratch (dot-prefixed): per-run resume partials, the cached
# state place-id map, and the sparse-cell report. The committed outputs are the
# non-dot data/phenology/<mode>.json files; everything dot-prefixed is
# regenerated by scripts/build_phenology_histograms.mjs.
data/phenology/.*

# iNaturalist access-cache: a build-only PAD-US containment intermediate
# (~8,900 files / ~269 MB), already excluded from serving via .assetsignore and
# never read at runtime (its result is baked into the manifest). Regenerated by
# `scripts/fetch_padus_containment.mjs --dir=inaturalist/us`. Unlike the smaller
# Falling Fruit cache, iNaturalist's is left out of git to keep the repo lean.
data/inaturalist/us/access-cache/
